generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  SUPERVISOR
  OPERATOR
  MAINTENANCE
  VIEWER
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  DISABLED
  DELETED
}

enum CompanyStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum PlantStatus {
  ACTIVE
  DISABLED
}

enum BoilerType {
  TUBOS_HUMO
  ACUOTUBULAR
  AGUA_CALIENTE
  ACEITE_TERMICO
  MIXTA
  OTRO
}

enum FuelType {
  GAS_NATURAL
  GAS_LP
  DIESEL
  COMBUSTOLEO
  DUAL
  BIOMASA
  OTRO
}

enum FuelPressureUnit {
  IN_H2O
  KG_CM2
}

enum FuelConsumptionUnit {
  M3N
  L
  KG
}

enum BoilerStatus {
  OPERANDO
  FUERA_SERVICIO
  MANTENIMIENTO
  STANDBY
}

enum ShiftType {
  MATUTINO
  VESPERTINO
  NOCTURNO
  PERSONALIZADO
}

enum LoadLevel {
  BAJA
  MEDIA
  ALTA
  PORCENTAJE_MANUAL
}

enum LogOperationalState {
  NORMAL
  OBSERVACION
  ALARMA
  FUERA_SERVICIO
}

enum ChecklistResponse {
  CUMPLE
  NO_CUMPLE
  NO_APLICA
}

enum LogStatus {
  BORRADOR
  ENVIADO
  REVISADO
  APROBADO
  RECHAZADO
  BLOQUEADO
}

enum MaintenancePriority {
  BAJA
  MEDIA
  ALTA
  CRITICA
}

enum AlertSeverity {
  NORMAL
  ADVERTENCIA
  CRITICO
}

enum AlertStatus {
  ABIERTA
  EN_REVISION
  CERRADA
}

enum MaintenanceType {
  PREVENTIVO
  CORRECTIVO
  PREDICTIVO
  INSPECCION
}

enum MaintenanceStatus {
  ABIERTA
  PROGRAMADA
  EN_PROCESO
  CERRADA
  CANCELADA
}

enum AuditAction {
  CREAR_REGISTRO
  EDITAR_REGISTRO
  APROBAR_REGISTRO
  RECHAZAR_REGISTRO
  BLOQUEAR_REGISTRO
  CREAR_USUARIO
  CAMBIAR_CONTRASENA
  CERRAR_ALERTA
  CREAR_MANTENIMIENTO
  CERRAR_MANTENIMIENTO
  CAMBIAR_LIMITES_CALDERA
}

model Company {
  id        String        @id @default(cuid())
  name      String
  status    CompanyStatus @default(ACTIVE)
  logoUrl   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  users   User[]
  plants  Plant[]
  boilers Boiler[]
}

model User {
  id                 String     @id @default(cuid())
  username           String     @unique
  email              String     @unique
  name               String
  passwordHash       String
  role               UserRole   @default(OPERATOR)
  status             UserStatus @default(PENDING_APPROVAL)
  companyId          String?
  rejectionReason    String?
  mustChangePassword Boolean    @default(false)
  passwordChangedAt  DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  company                 Company?             @relation(fields: [companyId], references: [id])
  boilerLogs              BoilerLog[]          @relation("OperatorLogs")
  reviewedLogs            BoilerLog[]          @relation("SupervisorReviews")
  alertsCaptured          Alert[]              @relation("AlertCapturedBy")
  maintenanceOrders       MaintenanceOrder[]   @relation("MaintenanceResponsible")
  auditLogs               AuditLog[]
  passwordResetTokens     PasswordResetToken[]
  attachments             Attachment[]

  @@index([companyId])
  @@index([status])
}

model Plant {
  id             String      @id @default(cuid())
  name           String
  normalizedName String
  client         String?
  location       String?
  address        String?
  contact        String?
  phone          String?
  email          String?
  notes          String?
  companyId      String?
  status         PlantStatus @default(ACTIVE)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  company Company? @relation(fields: [companyId], references: [id])
  boilers Boiler[]

  @@unique([companyId, normalizedName])
  @@index([companyId])
}

model Boiler {
  id                              String       @id @default(cuid())
  internalId                      String
  name                            String
  brand                           String?
  model                           String?
  serialNumber                    String?
  capacityHp                      Float?
  capacityKgH                     Float?
  capacityLbH                     Float?
  type                            BoilerType
  customType                      String?
  fuelType                        FuelType
  customFuelType                  String?
  designPressureKgCm2             Float?
  designPressureNotApplicable     Boolean      @default(false)
  operatingPressureKgCm2          Float?
  operatingPressureNotApplicable  Boolean      @default(false)
  operatingTemperatureC           Float?
  operatingTemperatureNotApplicable Boolean    @default(false)
  location                        String?
  installationDate                DateTime?
  lastInspectionDate              DateTime?
  nextInspectionDate              DateTime?
  status                          BoilerStatus @default(OPERANDO)
  technicalNotes                  String?
  plantId                         String?
  companyId                       String?
  createdAt                       DateTime     @default(now())
  updatedAt                       DateTime     @updatedAt

  company           Company?              @relation(fields: [companyId], references: [id])
  plant             Plant?                @relation(fields: [plantId], references: [id])
  operatingLimits   BoilerOperatingLimit?
  logs              BoilerLog[]
  alerts            Alert[]
  maintenanceOrders MaintenanceOrder[]

  @@unique([companyId, internalId])
  @@index([companyId])
}

model BoilerOperatingLimit {
  id                    String   @id @default(cuid())
  boilerId              String   @unique
  pressureMinKgCm2      Float?
  pressureMaxKgCm2      Float?
  temperatureMinC       Float?
  temperatureMaxC       Float?
  waterLevelMinPercent  Float?
  waterLevelMaxPercent  Float?
  conductivityMaxUsCm   Float?
  tdsMaxPpm             Float?
  phMin                 Float?
  phMax                 Float?
  hardnessMaxPpm        Float?
  o2MinPercent          Float?
  o2MaxPercent          Float?
  coMaxPpm              Float?
  stackTemperatureMaxC  Float?
  gasPressureMin        Float?
  gasPressureMax        Float?
  airPressureMin        Float?
  airPressureMax        Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  boiler Boiler @relation(fields: [boilerId], references: [id], onDelete: Cascade)
}

model BoilerLog {
  id                        String              @id @default(cuid())
  logDate                   DateTime            @default(now())
  boilerId                  String
  operatorId                String
  shift                     ShiftType
  customShift               String?
  accumulatedHours          Float?
  loadLevel                 LoadLevel?
  loadPercentage            Float?
  operationalState          LogOperationalState @default(NORMAL)
  steamPressureKgCm2        Float?
  steamTemperatureC         Float?
  feedwaterPressureKgCm2    Float?
  feedwaterTemperatureC     Float?
  condensateReturnTemperatureC Float?
  waterLevelPercent         Float?
  feedPumpStatus            String?
  alternatePumpStatus       String?
  feedPumpPressureKgCm2     Float?
  alternatePumpPressureKgCm2 Float?
  fuelPressureValue         Float?
  fuelPressureUnit          FuelPressureUnit?
  operatingFuelType         String?
  airPressure               Float?
  fanFrequencyHz            Float?
  modulationPositionDegrees Float?
  fuelConsumptionValue      Float?
  fuelConsumptionUnit       FuelConsumptionUnit?
  generalObservations       String?
  abnormalCondition         String?
  immediateCorrectiveAction String?
  requiresMaintenance       Boolean             @default(false)
  maintenancePriority       MaintenancePriority?
  operatorSignature         String?
  supervisorComments        String?
  status                    LogStatus           @default(BORRADOR)
  version                   Int                 @default(1)
  parentLogId               String?
  reviewedById              String?
  reviewedAt                DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt

  boiler            Boiler                     @relation(fields: [boilerId], references: [id])
  operator          User                       @relation("OperatorLogs", fields: [operatorId], references: [id])
  reviewedBy        User?                      @relation("SupervisorReviews", fields: [reviewedById], references: [id])
  parentLog         BoilerLog?                 @relation("LogVersions", fields: [parentLogId], references: [id])
  childVersions     BoilerLog[]                @relation("LogVersions")
  combustion        BoilerLogCombustion?
  waterTreatment    BoilerLogWaterTreatment?
  safetyChecklist   BoilerLogSafetyChecklist[]
  alerts            Alert[]
  maintenanceOrders MaintenanceOrder[]
  attachments       Attachment[]

  @@index([logDate])
  @@index([boilerId])
  @@index([operatorId])
  @@index([status])
}

model BoilerLogCombustion {
  id                  String  @id @default(cuid())
  boilerLogId         String  @unique
  flueGasTemperatureC Float?
  o2Percent           Float?
  coPpm               Float?
  co2Percent          Float?
  excessAirPercent    Float?
  estimatedEfficiencyPercent Float?
  steamFlowKgH        Float?

  boilerLog BoilerLog @relation(fields: [boilerLogId], references: [id], onDelete: Cascade)
}

model BoilerLogWaterTreatment {
  id                  String  @id @default(cuid())
  boilerLogId         String  @unique
  ph                  Float?
  conductivityUsCm    Float?
  tdsPpm              Float?
  tdsConversionFactor Float?
  hardnessPpmAsCaCO3  Float?
  sulfitesPpm         Float?
  phosphatesPpm       Float?
  alkalinityPpmAsCaCO3 Float?
  chloridesPpm        Float?
  bottomBlowdownDone  Boolean @default(false)
  surfaceBlowdownDone Boolean @default(false)
  softenerInService   Boolean @default(false)
  regenerationDone    Boolean @default(false)
  observations        String?

  boilerLog BoilerLog @relation(fields: [boilerLogId], references: [id], onDelete: Cascade)
}

model BoilerLogSafetyChecklist {
  id          String            @id @default(cuid())
  boilerLogId String
  itemKey     String
  itemLabel   String
  response    ChecklistResponse @default(CUMPLE)
  observation String?

  boilerLog BoilerLog @relation(fields: [boilerLogId], references: [id], onDelete: Cascade)

  @@unique([boilerLogId, itemKey])
}

model Alert {
  id              String        @id @default(cuid())
  alertDate       DateTime      @default(now())
  boilerId        String
  boilerLogId     String?
  parameter       String
  recordedValue   String?
  configuredLimit String?
  severity        AlertSeverity
  capturedById    String
  status          AlertStatus   @default(ABIERTA)
  closeComments   String?
  closedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  boiler            Boiler             @relation(fields: [boilerId], references: [id])
  boilerLog         BoilerLog?         @relation(fields: [boilerLogId], references: [id])
  capturedBy        User               @relation("AlertCapturedBy", fields: [capturedById], references: [id])
  maintenanceOrders MaintenanceOrder[]

  @@index([alertDate])
  @@index([boilerId])
  @@index([status])
  @@index([severity])
}

model MaintenanceOrder {
  id            String              @id @default(cuid())
  orderNumber   String              @unique
  boilerId      String
  type          MaintenanceType
  priority      MaintenancePriority @default(MEDIA)
  createdAt     DateTime            @default(now())
  scheduledDate DateTime?
  responsibleId String?
  description   String
  finding       String?
  actionTaken   String?
  partsUsed     String?
  status        MaintenanceStatus   @default(ABIERTA)
  alertId       String?
  boilerLogId   String?
  closedAt      DateTime?
  updatedAt     DateTime            @updatedAt

  boiler      Boiler                @relation(fields: [boilerId], references: [id])
  responsible User?                 @relation("MaintenanceResponsible", fields: [responsibleId], references: [id])
  alert       Alert?                @relation(fields: [alertId], references: [id])
  boilerLog   BoilerLog?            @relation(fields: [boilerLogId], references: [id])
  evidence    MaintenanceEvidence[]

  @@index([status])
  @@index([boilerId])
}

model MaintenanceEvidence {
  id                 String   @id @default(cuid())
  maintenanceOrderId String
  fileName           String
  fileUrl            String
  mimeType           String?
  uploadedAt         DateTime @default(now())

  maintenanceOrder MaintenanceOrder @relation(fields: [maintenanceOrderId], references: [id], onDelete: Cascade)
}

model Attachment {
  id           String   @id @default(cuid())
  fileName     String
  fileUrl      String
  mimeType     String?
  boilerLogId  String?
  uploadedById String?
  uploadedAt   DateTime @default(now())

  boilerLog  BoilerLog? @relation(fields: [boilerLogId], references: [id])
  uploadedBy User?      @relation(fields: [uploadedById], references: [id])
}

model ParameterDefinition {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  unit        String
  category    String
  description String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id            String      @id @default(cuid())
  userId        String?
  action        AuditAction
  module        String
  recordId      String?
  previousValue String?     @db.Text
  newValue      String?     @db.Text
  ipAddress     String?
  createdAt     DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([module])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
}
